#include <iostream>
#include <vector>
#include <cstdint>
using namespace std;

// L_1 : p(x) = x^30 + x^6 + x^4 + x + 1
// L_2 : p(x) = x^31 + x^3 + 1
// L_3 : p(x) = x^32 + x^7 + x^5 + x^3 + x^2 + x + 1
// alpha = 0.01

class LFSR {

private:
    uint32_t start_state;
    int Size;
    vector<int> taps;
    uint32_t mask;

public:
    LFSR(uint32_t seed, int n, vector<int> t){
        Size = n;
        taps = t;
        mask = (1ULL << Size) - 1;
        start_state = seed & mask;
    }

    uint32_t next_bit() {
        uint32_t output = start_state & 1;
        uint32_t feedback = 0;

        for (int t : taps) feedback ^= (start_state >> t) & 1;

        start_state >>= 1;
        start_state |= (feedback << (Size - 1));
        start_state &= mask;

        return output;
    }
};

class Geffe_Generator {

private:
    LFSR L_1;
    LFSR L_2;
    LFSR L_3;

public:

    Geffe_Generator(uint32_t x, uint32_t y, uint32_t s):
        L_1(x, 30, {29,5,3,0}),
        L_2(y, 31, {30,2,0}),
        L_3(s, 32, {31,6,4,2,1,0})
    {}

    uint32_t next_bit() {
        uint32_t x = L_1.next_bit();
        uint32_t y = L_2.next_bit();
        uint32_t s = L_3.next_bit();

        return (x & s) ^ ((s ^ 1) & y);
    }
};

int main() {

    Geffe_Generator g(1, 1, 1);

    for (int i = 0; i < 2048; i++) {
        cout << g.next_bit();
    }
}


