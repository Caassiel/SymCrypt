using namespace std;

class LFSR {

private:
    uint32_t state;
    int Size;
    vector<int> taps;
    uint32_t mask;

public:

    LFSR(uint32_t seed, int n, const vector<int>& t){
        Size = n;
        taps = t;
        mask = (Size == 32) ? 0xFFFFFFFFu : ((1u << Size) - 1u);
        state = seed & mask;

        if (state == 0) state = 1;
    }

    inline uint32_t next_bit() {

        uint32_t output = state & 1u;
        uint32_t feedback = 0;

        for (int t : taps) feedback ^= (state >> t) & 1u;

        state >>= 1;
        state |= (feedback << (Size - 1));
        state &= mask;

        return output;
    }

    void generate_packed(int N, vector<uint32_t>& out) {
        int words = (N + 31) / 32;
        out.assign(words, 0u);

        for (int i = 0; i < N; i++) {
            uint32_t bit = next_bit();
            out[i >> 5] |= (bit << (i & 31));
        }
    }
};

class Geffe_Generator {

private:
    LFSR L_1;
    LFSR L_2;
    LFSR L_3;

public:

    Geffe_Generator(uint32_t x, uint32_t y, uint32_t s):
        L_1(x, 30, {0,1,4,6}),
        L_2(y, 31, {0,3}),
        L_3(s, 32, {0,1,2,3,5,7})
    {}

    inline uint32_t next_bit() {

        uint32_t x = L_1.next_bit();
        uint32_t y = L_2.next_bit();
        uint32_t s = L_3.next_bit();

        return (x & s) ^ ((s ^ 1u) & y);
    }
};

int popcount_match(const vector<uint32_t>& a, const vector<uint32_t>& b, int N){
    int matches = 0;
    int full_words = N / 32;
    int rem = N % 32;

    for (int w = 0; w < full_words; w++) matches += __builtin_popcount(~(a[w] ^ b[w]));
    if (rem) {
        uint32_t mask = (1u << rem) - 1u;
        matches += __builtin_popcount(~(a[full_words] ^ b[full_words]) & mask);
    }

    return matches;
}



int main() {
//    const double C =  N/2 + 2.576 * sqrt(3*N)/2;
//    const double C = N - 6.1 * sqrt(N);
    const int N = 562;


    ifstream f("input.txt", ios::binary);
    if (!f) {
        cerr << "Cannot open file\n";
        return 1;
    }

    vector<uint32_t> observed_packed((N + 31) / 32, 0u);
    char byte;

    int i = 0;
    while (f.read(&byte, 1) && i < N) {
        observed_packed[i >> 5] |= ((uint32_t)(byte & 1) << (i & 31));
        i++;
    }

    auto get_bit = [&](int idx) -> uint32_t {
        return (observed_packed[idx >> 5] >> (idx & 31)) & 1u;
    };

    LFSR L1(812767230, 30, {0, 1, 4, 6});
    LFSR L2(947930218, 31, {0, 3});

    auto verify_seed = [&](int seed, int size, vector<int> taps, string name) {
    LFSR reg(seed, size, taps);
        int matches = 0;
        for (int t = 0; t < N; t++)
            matches += (reg.next_bit() == get_bit(t));  // wrong: this checks LFSR against z
        // correct check: score should be ~3N/4 ≈ 422
        cout << name << " seed " << seed << " scores " << matches << "/" << N << "\n";
    };
    verify_seed(812767230,  30, {0,1,4,6}, "L1");
    verify_seed(947930218,  31, {0,3},     "L2");

    vector<uint8_t> s_obs;

    for (int t = 0; t < N; t++) {

        uint32_t x = L1.next_bit();
        uint32_t y = L2.next_bit();
        uint32_t z = get_bit(t);

        if (x == y) continue;
        s_obs.push_back((z == x) ? 1 : 0);
    }

    LFSR verify_L3(1814788236, 32, {0,1,2,3,5,7});
    int exact = 0;
    for (int k = 0; k < (int)s_obs.size(); k++)
        exact += (verify_L3.next_bit() == s_obs[k]);
    cout << "L3 exact match: " << exact << "/" << s_obs.size() << "\n";

    // Also verify full Geffe reconstruction
    LFSR vL1(812767230, 30, {0,1,4,6});
    LFSR vL2(947930218, 31, {0,3});
    LFSR vL3(1814788236,  32, {0,1,2,3,5,7});
    int geffe_match = 0;
    for (int t = 0; t < N; t++) {
        uint32_t x = vL1.next_bit();
        uint32_t y = vL2.next_bit();
        uint32_t s = vL3.next_bit();
        uint32_t z = (x & s) ^ ((s ^ 1u) & y);
        geffe_match += (z == get_bit(t));
    }
    cout << "Full Geffe reconstruction: " << geffe_match << "/" << N << "\n";



    int best_seed  = -1;
    int best_score = -1;

    #pragma omp parallel
    {
        int local_best_seed  = -1;
        int local_best_score = -1;

        #pragma omp for schedule(static)
        for (uint64_t seed = 1; seed <= 0xFFFFFFFFu; seed++) {

            LFSR cand(seed, 32, {0,1,2,3,5,7});

            int score = 0;

            for (int k = 0; k < (int)s_obs.size(); k++) {
                score += (cand.next_bit() == s_obs[k]);
            }

            if (score > local_best_score) {
                local_best_score = score;
                local_best_seed  = seed;
            }
        }

        #pragma omp critical
        {
            if (local_best_score > best_score) {
                best_score = local_best_score;
                best_seed  = local_best_seed;
            }
        }
    }

    cout << "Recovered L3 seed = " << best_seed << "\n";
    cout << "Correlation score  = " << best_score
         << " / " << s_obs.size() << "\n";

    return 0;
}






