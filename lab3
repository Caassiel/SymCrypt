//stats
wstring decodeUtf8(const string& s) {
    wstring_convert<codecvt_utf8<wchar_t>> conv;
    return conv.from_bytes(s);
}

string encodeUtf8(const wstring& s) {
    wstring_convert<codecvt_utf8<wchar_t>> conv;
    return conv.to_bytes(s);
}

using CharFreq = map<wchar_t, long long>;
using BigramFreq = map<pair<wchar_t,wchar_t>, long long>;

struct Stats {
    CharFreq  cf;
    long long nc = 0;

    BigramFreq  bo;
    long long no = 0;

    BigramFreq  bn;
    long long nn = 0;
};

static Stats CalcStats(const wstring& t) {
    Stats s;
    for (wchar_t c : t) {
        s.cf[c]++; s.nc++;
    }

    for (size_t i = 0; i + 1 < t.size(); ++i) {
        s.bo[{t[i], t[i+1]}]++;
        s.no++;
    }
    for (size_t i = 0; i + 1 < t.size(); i += 2) {
        s.bn[{t[i], t[i+1]}]++;
        s.nn++;
    }
    return s;
}

//math
int gcdExtended(int a, int b, int &x, int &y) {
    if (a == 0)  {
        x = 0;
        y = 1;
        return b;
    }

    int x1, y1;
    int gcd = gcdExtended(b%a, a, x1, y1);

    x = y1 - (b/a) * x1;
    y = x1;
    return gcd;
}

int GCD(int a, int b) {
    int x = 1, y = 1;
    return gcdExtended(a, b, x, y);
}

vector<int> Solve_Linear_Congruence(int a, int b, int n){
    vector<int> solutions;
    int x, y;
    int d = gcdExtended(a, n, x, y);

    if (b % d != 0) return solutions;

    int b1 = b / d;
    int n1 = n / d;

    int x0 = (x * b1) % n1;
    if (x0 < 0) x0 += n1;

    for (int k = 0; k < d; k++)
        solutions.push_back((x0 + k * n1) % n);

    return solutions;
}

//attack
int mod_inverse(int a, int m) {
    int x, y;
    gcdExtended(a, m, x, y);
    return (x % m + m) % m;
}

int decrypt_symbol(int y, int a, int b, int m) {
    int inv = mod_inverse(a, m);
    int b0 = b % m;
    return (inv * (y - b0 + m)) % m;
}

vector<pair<pair<wchar_t,wchar_t>, long long>> Top_Bigrams(const BigramFreq& f, int topN) {

    vector<pair<pair<wchar_t,wchar_t>, long long>> v(f.begin(), f.end());

    sort(v.begin(), v.end(), [](auto& a, auto& b) {
        return a.second > b.second;
    });

    if ((int)v.size() > topN) v.resize(topN);
    return v;
}

map<wchar_t, int> Build_Alphabet_Map(const vector<wchar_t>& alpha) {
    map<wchar_t, int> mp;
    for (int i = 0; i < (int)alpha.size(); i++)
        mp[alpha[i]] = i;
    return mp;
}

int encode_bigram(int x1, int x2, int m) {
    return x1 * m + x2;
}


void Attack(const Stats& s, const vector<wchar_t>& alpha, const wstring& text) {
    const int m = 31;
    const int M = m * m;

    auto topCipher = Top_Bigrams(s.bn, 5);
    auto mp = Build_Alphabet_Map(alpha);

    vector<pair<int,int>> common_plain = {
        {17,18}, {13,14}, {18,14}, {13,0}, {5,13}
    };

    for (auto& [c1, f1] : topCipher) {
        for (auto& [c2, f2] : topCipher) {
            if (c1 == c2) continue;

            int Y1 = encode_bigram(mp[c1.first], mp[c1.second], m);
            int Y2 = encode_bigram(mp[c2.first], mp[c2.second], m);

            for (auto& p1 : common_plain) {
                for (auto& p2 : common_plain) {
                    if (p1 == p2) continue;

                    int X1 = encode_bigram(p1.first, p1.second, m);
                    int X2 = encode_bigram(p2.first, p2.second, m);

                    int A = (X1 - X2) % M;
                    if (A < 0) A += M;

                    int B = (Y1 - Y2) % M;
                    if (B < 0) B += M;

                    auto sols = Solve_Linear_Congruence(A, B, M);

                    for (int a : sols) {
                        if (GCD(a, m) != 1) continue;

                        int b = (Y1 - a * X1) % M;
                        if (b < 0) b += M;

                        wstring decrypted;

                        int inv = mod_inverse(a, M);
                        for (size_t i = 0; i + 1 < text.size(); i += 2) {
                            if (!mp.count(text[i]) || !mp.count(text[i+1])) {
                                decrypted += text[i];
                                decrypted += text[i+1];
                                continue;
                            }
                            int Y = mp[text[i]] * m + mp[text[i+1]];
                            int X = (1LL * inv * ((Y - b + M) % M)) % M;
                            decrypted += alpha[X / m];
                            decrypted += alpha[X % m];
                        }

                        int score1 = 0; int score2 = 0;
                        for (wchar_t c : decrypted) {
                            if (c == L'о' || c == L'е' || c == L'а') score1++;
                        }
                        for (wchar_t c : decrypted) {
                            if (c == L'ф' || c == L'щ' || c == L'ь' || c == L'х' || c == L'ш' || c == L'ч') score2++;
                        }
                        double len = decrypted.size();

                        double freq_good = score1 / len;
                        double freq_bad  = score2 / len;

                        if (freq_good > 0.15 && freq_bad < 0.07) {
                            cout << "Candidate:  a=" << a << " b=" << b << "\n";
                            cout << encodeUtf8(decrypted.substr(0, 200)) << "\n";
                            cout << "fg=" << freq_good << " fb=" << freq_bad << "\n\n";
                        }
                    }
                }
            }
        }
    }
}


