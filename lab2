using namespace std;

wstring decodeUtf8(const string& s) {
    wstring_convert<codecvt_utf8<wchar_t>> conv;
    return conv.from_bytes(s);
}

string encodeUtf8(const wstring& s) {
    wstring_convert<codecvt_utf8<wchar_t>> conv;
    return conv.to_bytes(s);
}

static bool isLetter(wchar_t c) {
    return  (c >= 0x0410 && c <= 0x044F) || c == 0x0401 || c == 0x0451;
}

static wchar_t toLower(wchar_t c) {
    if (c >= 0x0410 && c <= 0x042F)     return c + 0x20;
    if (c == 0x0401 || c == 0x0451)     return 0x0435;
    return c;
}

static wstring stripSpaces(const wstring& t) {
    wstring r;
    for (wchar_t c : t) if (c != L' ') r += c;
    return r;
}

static wstring NormaliseWithSpaces(const wstring& t) {
    wstring r;
    bool special_char = true;
    for (wchar_t c : t) {
        if (isLetter(c)) {
            r += toLower(c);
            special_char = false;
        } else {
            if (!special_char) { r += L' '; special_char = true; }
        }
    }
    if (!r.empty() && r.back() == L' ') r.pop_back();
    return r;
}

static wstring NormaliseWithoutSpaces(const wstring& t) {
    return stripSpaces(NormaliseWithSpaces(t));
}

static wchar_t Encrypt(wchar_t a, wchar_t b) {
    return (a - 0x0430 + b - 0x0430) % 32 + 0x0430;
}

static wchar_t Decrypt(wchar_t a, wchar_t b) {
    return ((a - 0x0430) - (b - 0x0430) + 32) % 32 + 0x0430;
}

static wstring EncryptText(const wstring& text, const wstring& key) {
    wstring r;
    for (size_t i = 0; i < text.size(); i++) {
        r += Encrypt(text[i], key[i % key.size()]);
    }
    return r;
}

static wstring DecryptText(const wstring& text, const wstring& key) {
    wstring r;
    for (size_t i = 0; i < text.size(); i++) {
        r += Decrypt(text[i], key[i % key.size()]);
    }
    return r;
}

using CharFreq = map<wchar_t, long long>;
using BigramFreq = map<pair<wchar_t,wchar_t>, long long>;

struct Stats {
    CharFreq  cf;
    long long nc = 0;

    BigramFreq  bo;
    long long no = 0;

    BigramFreq  bn;
    long long nn = 0;
};

static Stats CalcStats(const wstring& t) {
    Stats s;
    for (wchar_t c : t) {
        s.cf[c]++; s.nc++;
    }

    for (size_t i = 0; i + 1 < t.size(); ++i) {
        s.bo[{t[i], t[i+1]}]++;
        s.no++;
    }
    for (size_t i = 0; i + 1 < t.size(); i += 2) {
        s.bn[{t[i], t[i+1]}]++;
        s.nn++;
    }
    return s;
}

static double Index_of_coincidence(const wstring& t) {

    double I = 0;
    Stats s = CalcStats(t);
    long long N = s.nc;

    for (auto& [c, freq] : s.cf) {
        I += freq * (freq - 1);
    }
    I = I / (N * (N - 1));
    return I;
}

static int Delta(const wstring& t, const int r) {
    int D = 0;
    for (unsigned int i = 0; i + r < t.size(); i++){
        if (t[i] == t[i+r]) D++;
    }
    return D;
}

static vector<wchar_t> TopChars(const wstring& group, int n = 3) {
    map<wchar_t, int> freq;
    for (wchar_t c : group) freq[c]++;

    vector<pair<int, wchar_t>> sorted;
    for (auto& [c, f] : freq) sorted.push_back({f, c});
    sort(sorted.rbegin(), sorted.rend());

    vector<wchar_t> result;
    for (int i = 0; i < n && i < (int)sorted.size(); i++)
        result.push_back(sorted[i].second);
    return result;
}

static wchar_t GuessKeyChar(const wstring& group, wchar_t assumed_plain = L'о') {
    wchar_t most_common = TopChars(group, 1)[0];
    return (most_common - assumed_plain + 32) % 32 + 0x0430;
}

static wstring GuessKey(const wstring& ciphertext, int keylen) {
    wstring key;
    for (int i = 0; i < keylen; i++) {
        wstring group;
        for (size_t j = i; j < ciphertext.size(); j += keylen)
            group += ciphertext[j];
        key += GuessKeyChar(group);
    }
    return key;
}


static vector<double> LoadProbs(const string& filename) {
    ifstream f(filename);
    vector<double> probs(32, 0.0);
    wstring_convert<codecvt_utf8<wchar_t>> conv;

    string letter_utf8;
    double p;
    while (f >> letter_utf8 >> p) {
        wstring letter = conv.from_bytes(letter_utf8);
        if (!letter.empty()) {
            int idx = toLower(letter[0]) - 0x0430;
            if (idx >= 0 && idx < 32)
                probs[idx] = p / 100.0;
        }
    }
    return probs;
}

static double Mg(const wstring& block, int g, const vector<double>& probs) {

    vector<long long> counts(32, 0);
    for (wchar_t c : block)
        counts[c - 0x0430]++;

    double sum = 0.0;
    for (int t = 0; t < 32; t++)
        sum += probs[t] * counts[(t + g) % 32];

    return sum;
}

static wchar_t BestShift(const wstring& block, const vector<double>& probs) {
    int best_g = 0;
    double best_score = -1.0;
    for (int g = 0; g < 32; g++) {
        double score = Mg(block, g, probs);
        if (score > best_score) { best_score = score; best_g = g; }
    }
    return 0x0430 + best_g;
}




